PREPMIND_ENV=development
PREPMIND_DATABASE_URL=sqlite:///./data/prepmind.db
PREPMIND_UPLOAD_DIR=./uploads
PREPMIND_FRONTEND_ORIGIN=http://localhost:5173
PREPMIND_SESSION_SECRET=change-this-session-secret
PREPMIND_SESSION_HTTPS_ONLY=false

# Gemini
# You can use either the PREPMIND_* names below or the plain GEMINI_* names.
PREPMIND_GEMINI_API_KEY=your-gemini-api-key
PREPMIND_GEMINI_CHAT_MODEL=gemini-2.5-flash
PREPMIND_GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_CHAT_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Optional OpenAI fallback
PREPMIND_OPENAI_API_KEY=
PREPMIND_OPENAI_CHAT_MODEL=gpt-5
PREPMIND_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
