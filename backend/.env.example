PREPMIND_APP_NAME=PrepMind AI
PREPMIND_ENV=development
PREPMIND_DATABASE_URL=sqlite:///./data/prepmind.db
PREPMIND_UPLOAD_DIR=./uploads
PREPMIND_DEMO_EMAIL=demo@prepmind.local
PREPMIND_DEMO_NAME=PrepMind Demo
PREPMIND_FRONTEND_ORIGIN=http://localhost:5173
PREPMIND_SESSION_SECRET=change-me-for-production
PREPMIND_SESSION_COOKIE_NAME=prepmind_session
PREPMIND_SESSION_MAX_AGE=604800
PREPMIND_SESSION_HTTPS_ONLY=false
PREPMIND_OPENAI_BASE_URL=https://api.openai.com/v1
PREPMIND_OPENAI_CHAT_MODEL=gpt-5
PREPMIND_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
